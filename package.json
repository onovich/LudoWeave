{
  "name": "ludoweave",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "api-check": "node tooling/api-check.mjs",
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --filter @ludoweave/playground dev",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "structure-check": "node tooling/boundary-check/check-import-boundaries.mjs",
    "test": "vitest run --passWithNoTests",
    "test:a11y": "playwright test tests/a11y",
    "test:e2e": "playwright test tests/e2e",
    "typecheck": "pnpm -r --if-present typecheck",
    "validate": "pnpm lint && pnpm typecheck && pnpm build && pnpm test && pnpm structure-check && pnpm api-check"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.9",
    "@playwright/test": "^1.61.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
